# iOS Fastlane Configuration

default_platform(:ios)

platform :ios do
  desc "Build and deploy staging to TestFlight"
  lane :staging do
    # Set environment file for staging
    ENV['ENVFILE'] = '.env.staging'
    
    # Sync code signing
    setup_ci if ENV['CI']
    
    # Use match to sync certificates and provisioning profiles
    match(
      type: "appstore",
      readonly: true,
      app_identifier: "org.sera.dev.bisetka.staging"
    )
    
    # Build the app
    gym(
      workspace: "bisetka.xcworkspace",
      scheme: "bisetka-staging",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "bisetka-staging.ipa",
      clean: true
    )
    
    # Upload to TestFlight
    if ENV['APP_STORE_API_KEY_ID']
      upload_to_testflight(
        api_key_path: "./fastlane/api_key.json",
        skip_waiting_for_build_processing: true,
        skip_submission: true,
        distribute_external: false,
        notify_external_testers: false
      )
    else
      UI.important("⚠️  APP_STORE_API_KEY_ID not set - skipping TestFlight upload")
    end
  end
  
  desc "Build production release"
  lane :production do
    # Set environment file for production
    ENV['ENVFILE'] = '.env'
    
    setup_ci if ENV['CI']
    
    gym(
      workspace: "bisetka.xcworkspace",
      scheme: "bisetka",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "bisetka.ipa",
      clean: true
    )
    
    if ENV['APP_STORE_API_KEY_ID']
      upload_to_testflight(
        api_key_path: "./fastlane/api_key.json",
        skip_waiting_for_build_processing: false,
        distribute_external: true
      )
    end
  end
end
