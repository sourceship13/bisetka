# iOS Fastlane Configuration

default_platform(:ios)

platform :ios do
  desc "Build and deploy staging to TestFlight"
  lane :staging do
    # Set environment file for staging
    ENV['ENVFILE'] = '.env.staging'
    
    # Sync code signing
    setup_ci if ENV['CI']
    
    # Use match to sync certificates and provisioning profiles
    match(
      type: "appstore",
      readonly: true,
      app_identifier: "org.sera.dev.bisetka.staging"
    )

    # Force manual signing so Xcode uses the match profile (env var set by match includes timestamp suffix)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "bisetka.xcodeproj",
      targets: ["bisetka-staging"],
      team_id: "CM52HNMXXW",
      code_sign_identity: "iPhone Distribution",
      profile_name: ENV["sigh_org.sera.dev.bisetka.staging_appstore_profile-name"]
    )

    # Build the app
    gym(
      workspace: "bisetka.xcworkspace",
      scheme: "bisetka-staging",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "bisetka-staging.ipa",
      clean: true
    )
    
    # Upload to TestFlight
    if ENV['APP_STORE_API_KEY_ID']
      upload_to_testflight(
        api_key_path: "./fastlane/api_key.json",
        skip_waiting_for_build_processing: true,
        skip_submission: true,
        distribute_external: false,
        notify_external_testers: false
      )
    else
      UI.important("⚠️  APP_STORE_API_KEY_ID not set - skipping TestFlight upload")
    end
  end
  
  desc "Build production release"
  lane :production do
    # Set environment file for production
    ENV['ENVFILE'] = '.env'
    
    # Sync code signing
    setup_ci if ENV['CI']
    
    # Use match to sync certificates and provisioning profiles
    match(
      type: "appstore",
      readonly: true,
      app_identifier: "org.sera.dev.bisetka"
    )

    # Force manual signing so Xcode uses the match profile (env var set by match includes timestamp suffix)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "bisetka.xcodeproj",
      targets: ["bisetka"],
      team_id: "CM52HNMXXW",
      code_sign_identity: "iPhone Distribution",
      profile_name: ENV["sigh_org.sera.dev.bisetka_appstore_profile-name"]
    )

    # Auto-increment build number from latest TestFlight build
    build_num = latest_testflight_build_number(
      api_key_path: "./fastlane/api_key.json",
      app_identifier: "org.sera.dev.bisetka"
    )
    increment_build_number(
      build_number: build_num + 1,
      xcodeproj: "bisetka.xcodeproj"
    )

    # Build the app
    gym(
      workspace: "bisetka.xcworkspace",
      scheme: "bisetka",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "bisetka.ipa",
      clean: true,
      export_options: {
        method: "app-store",
        teamID: "CM52HNMXXW",
        provisioningProfiles: {
          "org.sera.dev.bisetka" => ENV["sigh_org.sera.dev.bisetka_appstore_profile-name"]
        }
      }
    )
    
    # Upload to TestFlight
    if ENV['APP_STORE_API_KEY_ID']
      upload_to_testflight(
        api_key_path: "./fastlane/api_key.json",
        skip_waiting_for_build_processing: true,
        skip_submission: true,
        distribute_external: false,
        notify_external_testers: false
      )
    else
      UI.important("⚠️  APP_STORE_API_KEY_ID not set - skipping TestFlight upload")
    end
  end

  desc "Regenerate provisioning profiles with Push Notifications enabled. Run this after enabling Push Notifications in Apple Developer Portal."
  lane :sync_push_profiles do
    match(
      type: "appstore",
      readonly: false,
      force: true,
      app_identifier: ["org.sera.dev.bisetka", "org.sera.dev.bisetka.staging"]
    )
    UI.success("✅ Provisioning profiles regenerated with Push Notifications!")
  end

  desc "Generate all required iOS app icon sizes from the 1024x1024 source image"
  lane :icons do
    appicon(
      appicon_image_file: "../assets/appIcons/app-icon.png",
      appicon_devices: [:iphone, :ios_marketing],
      appicon_path: "bisetka/Images.xcassets"
    )
  end
end  # end of platform :ios
