# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# react-native-permissions setup
require_relative '../node_modules/react-native-permissions/scripts/setup'

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Pin MapboxMaps native SDK to v10.x — @rnmapbox/maps@10.x (RNMBXShapeSource etc.)
# uses the `Shape` type which was renamed to `GeoJSONObject` in MapboxMaps 11.x.
# Without this, pod install resolves to 11.x and the rnmapbox-maps target fails
# to compile ("cannot find 'Shape' in scope").
$RNMapboxMapsVersion = '= 10.18.2'

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

def shared_pods
  config = use_native_modules!

  # RNWorklets is a dependency of RNReanimated and needs explicit linking
  pod 'RNWorklets', :path => '../node_modules/react-native-worklets'
  
  # Explicitly enable modular headers for GoogleUtilities to fix Firebase
  pod 'GoogleUtilities', :modular_headers => true
  # Firebase App Check (AppCheckCore) is Swift and imports RecaptchaInterop,
  # which is an ObjC pod without a module map. Force a modular header so
  # Swift can import it when linking as static libraries. Without this,
  # `pod install` fails with:
  #   "The Swift pod `AppCheckCore` depends upon `RecaptchaInterop`, which
  #    does not define modules."
  pod 'RecaptchaInterop', :modular_headers => true

  # NOTE: Viro (@viro-community/react-viro) was removed on 2026-05-21.
  # The games use the WebView+Three.js based AR3DOverlay.tsx, not Viro.
  # Viro's prebuilt static lib also blocked iOS-simulator builds on Apple
  # Silicon. The ARViroOverlay.tsx component was disabled (see that file).

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )
  
  return config
end

# react-native-permissions: declare only the permissions used in the app
setup_permissions([
  'Notifications',
  'LocationWhenInUse',
  'Microphone',
])

target 'bisetka' do
  config = shared_pods
end

target 'bisetka-staging' do
  config = shared_pods
end

pre_install do |installer|
  $RNMapboxMaps.pre_install(installer)
end

post_install do |installer|
  $RNMapboxMaps.post_install(installer)
  # Note: use_native_modules! returns config which contains :reactNativePath
  # We can safely use the path from node_modules since it's shared across targets
  react_native_post_install(
    installer,
    '../node_modules/react-native',
    :mac_catalyst_enabled => false,
    # :ccache_enabled => true
  )

  # -- fmt 11.0.2 / Apple Clang (Xcode 26+) fix ------------------------------
  # Apple Clang in Xcode 26 has broken consteval support that causes
  # "Call to consteval function ... is not a constant expression" errors in
  # fmt's format-inl.h.  The compiler flag -DFMT_USE_CONSTEVAL=0 alone is
  # not sufficient because base.h's detection logic can still enable it.
  #
  # We forcibly replace the entire consteval detection block in base.h to
  # unconditionally disable consteval, and also blank out FMT_CONSTEVAL.
  fmt_base_h = "#{installer.sandbox.root}/fmt/include/fmt/base.h"
  if File.exist?(fmt_base_h)
    content = File.read(fmt_base_h)
    # Force FMT_USE_CONSTEVAL to 0 by replacing the entire detection block
    unless content.include?('// [PATCHED] Force-disable consteval')
      # 1. Replace the consteval detection block to always yield 0
      patched = content.gsub(
        /\/\/ Detect consteval.*?#define FMT_USE_CONSTEVAL \d\n#endif/m,
        "// [PATCHED] Force-disable consteval for Apple Clang (Xcode 26+)\n#undef FMT_USE_CONSTEVAL\n#define FMT_USE_CONSTEVAL 0"
      )
      # 2. Force FMT_CONSTEVAL to empty (constexpr at most)
      patched = patched.gsub(
        /#if FMT_USE_CONSTEVAL\n#\s*define FMT_CONSTEVAL consteval\n#\s*define FMT_CONSTEXPR20 constexpr\n#else\n#\s*define FMT_CONSTEVAL\n#\s*define FMT_CONSTEXPR20\n#endif/m,
        "#undef FMT_CONSTEVAL\n#define FMT_CONSTEVAL\n#undef FMT_CONSTEXPR20\n#define FMT_CONSTEXPR20"
      )
      File.chmod(0644, fmt_base_h)
      File.write(fmt_base_h, patched)
      Pod::UI.puts "  [fmt patch] Force-disabled consteval in fmt/base.h for Xcode 26+".yellow
    end
  end

  # -- Build settings for all pod targets -------------------------------------
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # Enforce minimum deployment target for MapboxMaps compatibility
      if config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f < 14.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      end
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'

      # Fix for Xcode 26.2 module building issues
      config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

      # Enable modular headers only for Firebase pods
      if target.name.include?('Firebase') || target.name.include?('GoogleUtilities')
        config.build_settings['DEFINES_MODULE'] = 'YES'
      end

      # Apply fmt consteval fix to every pod target (fmt headers are included
      # by React-RuntimeHermes, React-jserrorhandler, React-utils, RCT-Folly ...)
      flags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || '$(inherited)'
      unless flags.include?('FMT_USE_CONSTEVAL')
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = "#{flags} -DFMT_USE_CONSTEVAL=0 -DFMT_USE_NONTYPE_TEMPLATE_ARGS=0"
      end
    end
  end


  # -- JitsiWebRTC / CocoaPods script sandboxing fix (Xcode 15+) --------------
  # Xcode 15+ introduced "User Script Sandboxing" which restricts what build
  # phase scripts can access.  CocoaPods-generated embedding scripts (e.g.
  # JitsiWebRTC-xcframeworks.sh) write to $PODS_XCFRAMEWORKS_BUILD_DIR, which
  # is outside the script's declared output sandbox and causes
  # "PhaseScriptExecution failed with a nonzero exit code".
  # Setting ENABLE_USER_SCRIPT_SANDBOXING=NO in the aggregate-target xcconfigs
  # (Pods-bisetka.{debug,release}.xcconfig) propagates the setting to the main
  # app targets that include those xcconfigs.
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.xcconfigs.each do |config_name, config_file|
      config_file.attributes['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      xcconfig_path = aggregate_target.xcconfig_path(config_name)
      config_file.save_as(xcconfig_path)
    end
  end

  # -- Strip bitcode from Mapbox prebuilt frameworks --------------------------
  # App Store Connect rejects binaries containing bitcode (deprecated in
  # Xcode 14). Mapbox's vendored xcframeworks (MapboxCommon, MapboxCoreMaps,
  # MapboxMaps, MapboxMobileEvents, MapboxDirections, …) still ship with
  # bitcode embedded, so strip every Mach-O slice in their xcframeworks
  # in-place before CocoaPods embeds them into the app bundle.
  pods_root = installer.sandbox.root.to_s
  Dir.glob("#{pods_root}/**/*.xcframework").each do |xcf|
    next unless File.basename(xcf) =~ /Mapbox/i
    Dir.glob("#{xcf}/**/*.framework").each do |fw|
      bin = File.join(fw, File.basename(fw, '.framework'))
      next unless File.file?(bin)
      out = `xcrun bitcode_strip -r "#{bin}" -o "#{bin}" 2>&1`
      Pod::UI.puts "  [bitcode strip] #{bin.sub(pods_root + '/', '')}".yellow
      Pod::UI.puts "    #{out.strip}".red unless $?.success?
    end
  end
end
